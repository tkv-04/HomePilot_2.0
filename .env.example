# ============================================================
# HomePilot Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ============================================================

# --- Picovoice (Wake Word) ---
# Get your free key at: https://console.picovoice.ai
PICOVOICE_ACCESS_KEY=

# --- Home Assistant ---
# Long-lived access token from HA Profile page
HA_ACCESS_TOKEN=
HA_LOCAL_URL=http://homeassistant.local:8123
HA_CLOUD_URL=

# --- General ---
HOMEPILOT_LOG_LEVEL=INFO
HOMEPILOT_ASSISTANT_NAME=Jarvis
HOMEPILOT_LANGUAGE=en

# --- Audio (optional, leave blank for system default) ---
AUDIO_INPUT_DEVICE=
AUDIO_OUTPUT_DEVICE=

# --- Security ---
# Path to the Fernet encryption key file
TOKEN_ENCRYPTION_KEY_FILE=data/.keyfile
